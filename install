#!/bin/bash
# install — Bootstrap installer for ham-apps
#
# Usage:
#   curl -fsSL https://raw.githubusercontent.com/KW4JLB/ham-apps/main/install | bash
#   bash install [--help] [--dry-run]
#
# Environment overrides:
#   HAMAPPS_DIR   — installation directory (default: $HOME/ham-apps)

set -euo pipefail

# ---------------------------------------------------------------------------
# Inline colour helpers (cannot source scripts/utils — this runs before install)
# ---------------------------------------------------------------------------
info()    { echo -e "\e[34m[INFO]\e[0m  $*"; }
success() { echo -e "\e[32m[OK]\e[0m    $*"; }
warning() { echo -e "\e[33m[WARN]\e[0m  $*" >&2; }
error()   { echo -e "\e[31m[ERROR]\e[0m $*" >&2; }
die()     { error "$*"; exit 1; }

# ---------------------------------------------------------------------------
# Argument parsing
# ---------------------------------------------------------------------------
DRY_RUN=0

usage() {
  cat <<'EOF'
Usage: bash install [OPTIONS]

Bootstrap ham-apps on a Debian 11+ or Ubuntu 20.04+ system.

Options:
  --help, -h     Show this help message and exit
  --dry-run      Print planned actions without executing them

Environment variables:
  HAMAPPS_DIR    Installation directory (default: $HOME/ham-apps)

Example:
  curl -fsSL https://raw.githubusercontent.com/KW4JLB/ham-apps/main/install | bash
  HAMAPPS_DIR=/opt/ham-apps bash install
EOF
}

for arg in "$@"; do
  case "$arg" in
    --help|-h)
      usage
      exit 0
      ;;
    --dry-run)
      DRY_RUN=1
      ;;
    *)
      die "Unknown option: $arg  (try --help)"
      ;;
  esac
done

# ---------------------------------------------------------------------------
# Dry-run command wrapper
# ---------------------------------------------------------------------------
run_cmd() {
  if [[ $DRY_RUN -eq 1 ]]; then
    echo "[DRY-RUN] would: $*"
  else
    "$@"
  fi
}

# ---------------------------------------------------------------------------
# OS detection
# ---------------------------------------------------------------------------
check_os() {
  local os_release="${HAMAPPS_TEST_OS_RELEASE:-/etc/os-release}"
  if [[ ! -f "$os_release" ]]; then
    die "Cannot detect OS: $os_release not found."
  fi

  local ID VERSION_ID
  # shellcheck source=/dev/null
  . "$os_release"

  case "${ID:-}" in
    debian)
      if [[ "${VERSION_ID:-0}" -lt 11 ]]; then
        die "Unsupported Debian version ${VERSION_ID}. Requires Debian 11 (bullseye) or later."
      fi
      ;;
    ubuntu)
      local major minor
      major="${VERSION_ID%%.*}"
      minor="${VERSION_ID##*.}"
      if [[ "$major" -lt 20 ]] || { [[ "$major" -eq 20 ]] && [[ "$minor" -lt 4 ]]; }; then
        die "Unsupported Ubuntu version ${VERSION_ID}. Requires Ubuntu 20.04 or later."
      fi
      ;;
    *)
      die "Unsupported OS: ${ID:-unknown}. ham-apps requires Debian 11+ or Ubuntu 20.04+."
      ;;
  esac
}

# ---------------------------------------------------------------------------
# Install directory validation (CWE-78: command injection prevention)
# ---------------------------------------------------------------------------
validate_install_dir() {
  local dir="$1"
  if [[ "$dir" =~ [\$\(\)\`\;\|\&\<\>\"\'\\] ]]; then
    die "HAMAPPS_DIR contains invalid characters. Use a plain filesystem path."
  fi
  if [[ "$dir" != /* && "$dir" != "~"* ]]; then
    die "HAMAPPS_DIR must be an absolute path (e.g. /home/user/ham-apps)."
  fi
}

# ---------------------------------------------------------------------------
# Detect CPU architecture (shared by install_go and install_release)
# ---------------------------------------------------------------------------
detect_arch() {
  case "$(uname -m)" in
    x86_64)        echo "amd64" ;;
    aarch64|arm64) echo "arm64" ;;
    *) die "Unsupported architecture: $(uname -m). ham-apps supports amd64 and arm64." ;;
  esac
}

# ---------------------------------------------------------------------------
# Base dependency installation (only curl is required before Go is set up)
# ---------------------------------------------------------------------------
install_deps() {
  if ! command -v curl &>/dev/null; then
    info "Installing curl ..."
    run_cmd sudo apt-get update -qq
    run_cmd sudo apt-get install -y curl
  else
    info "curl already installed."
  fi
}

# ---------------------------------------------------------------------------
# Go installation
# Ensures Go 1.21+ is present. Downloads the latest stable release from
# golang.org if Go is absent or the installed version is too old.
# ---------------------------------------------------------------------------
GO_MIN_MAJOR=1
GO_MIN_MINOR=21

install_go() {
  local arch
  arch="$(detect_arch)"

  # Check existing Go installation
  if command -v go &>/dev/null; then
    local ver major minor
    ver="$(go version | grep -oE '[0-9]+\.[0-9]+' | head -1)"
    major="${ver%%.*}"
    minor="${ver##*.}"
    if [[ "$major" -gt "$GO_MIN_MAJOR" ]] || \
       { [[ "$major" -eq "$GO_MIN_MAJOR" ]] && [[ "$minor" -ge "$GO_MIN_MINOR" ]]; }; then
      info "Go ${ver} already installed — meets minimum ${GO_MIN_MAJOR}.${GO_MIN_MINOR}."
      return 0
    fi
    warning "Go ${ver} is too old (need ${GO_MIN_MAJOR}.${GO_MIN_MINOR}+). Installing newer version..."
  fi

  local go_version
  go_version="$(curl -fsSL 'https://go.dev/VERSION?m=text' | head -1)"
  if [[ -z "$go_version" ]]; then
    die "Could not determine latest Go version from go.dev."
  fi

  local download_url="https://go.dev/dl/${go_version}.linux-${arch}.tar.gz"
  local tmpfile
  tmpfile="$(mktemp --suffix=.tar.gz)"

  info "Downloading ${go_version} (linux/${arch}) ..."
  if ! run_cmd curl -fsSL --output "$tmpfile" "$download_url"; then
    rm -f "$tmpfile"
    die "Failed to download Go from ${download_url}"
  fi

  info "Installing Go to /usr/local ..."
  run_cmd sudo rm -rf /usr/local/go
  run_cmd sudo tar -C /usr/local -xzf "$tmpfile"
  rm -f "$tmpfile"

  # Make Go available in the current session so subsequent steps can use it
  export PATH="/usr/local/go/bin:$PATH"
  success "Go ${go_version} installed."
}

# ---------------------------------------------------------------------------
# Release installation
# Fetches the latest GitHub release tag, then downloads the release tarball
# which contains the ham-apps-gui binary plus apps/, scripts/, and data/.
# Falls back to building from source if the tarball is unavailable.
# ---------------------------------------------------------------------------
install_release() {
  local hamapps_dir="$1"
  local arch
  arch="$(detect_arch)"

  local latest_tag
  latest_tag="$(curl -fsSL 'https://api.github.com/repos/KW4JLB/ham-apps/releases/latest' \
    2>/dev/null | grep '"tag_name"' | head -1 | sed 's/.*"tag_name": *"\([^"]*\)".*/\1/')"

  if [[ -z "$latest_tag" ]]; then
    die "Could not determine latest release from GitHub API."
  fi

  info "Installing ham-apps ${latest_tag} ..."
  mkdir -p "$hamapps_dir"

  # --- Attempt 1: download the all-in-one release tarball ---
  local tarball_url="https://github.com/KW4JLB/ham-apps/releases/download/${latest_tag}/ham-apps-${latest_tag}-linux-${arch}.tar.gz"
  local tmpfile
  tmpfile="$(mktemp --suffix=.tar.gz)"

  if run_cmd curl -fsSL --output "$tmpfile" "$tarball_url" 2>/dev/null; then
    run_cmd tar -xzf "$tmpfile" -C "$hamapps_dir" --strip-components=1
    rm -f "$tmpfile"
    success "ham-apps ${latest_tag} installed at ${hamapps_dir}"
    return 0
  fi

  rm -f "$tmpfile"
  warning "Release tarball not found. Attempting to build from source..."

  # --- Attempt 2: build GUI from source using Go ---
  if ! command -v go &>/dev/null; then
    die "Go is not available and no pre-built release tarball was found for ${latest_tag}."
  fi

  local gui_dir="$hamapps_dir/gui"
  if [[ ! -d "$gui_dir" ]]; then
    die "No gui/ directory found at ${hamapps_dir}. Cannot build from source without the repository."
  fi

  info "Building ham-apps-gui from source ..."
  if run_cmd make -C "$gui_dir" build; then
    success "ham-apps-gui built from source at ${gui_dir}/ham-apps-gui"
  else
    die "Source build failed. See https://kw4jlb.github.io/ham-apps/getting-started/installation/"
  fi
}

# ---------------------------------------------------------------------------
# PATH configuration — ham-apps binary and Go toolchain
# ---------------------------------------------------------------------------
configure_path() {
  local hamapps_dir="${HAMAPPS_DIR:-$HOME/ham-apps}"
  local bashrc="${BASHRC_FILE:-$HOME/.bashrc}"
  local zshrc="$HOME/.zshrc"

  local hamapps_line="export PATH=\"${hamapps_dir}:\$PATH\""
  # shellcheck disable=SC2016  # $PATH must stay literal for the shell config line
  local go_line='export PATH="/usr/local/go/bin:$PATH"'

  _append_if_missing() {
    local file="$1" line="$2" label="$3"
    if ! grep -qF "$line" "$file" 2>/dev/null; then
      run_cmd bash -c "echo '$line' >> '$file'"
      info "Added ${label} to PATH in ${file}"
    else
      info "${label} PATH already set in ${file} — skipping."
    fi
  }

  _append_if_missing "$bashrc" "$hamapps_line" "ham-apps"
  _append_if_missing "$bashrc" "$go_line"      "Go"

  if [[ -f "$zshrc" ]]; then
    _append_if_missing "$zshrc" "$hamapps_line" "ham-apps"
    _append_if_missing "$zshrc" "$go_line"      "Go"
  fi
}

# ---------------------------------------------------------------------------
# Success banner
# ---------------------------------------------------------------------------
print_banner() {
  local dir="${HAMAPPS_DIR:-$HOME/ham-apps}"
  local bashrc="${BASHRC_FILE:-$HOME/.bashrc}"
  echo ""
  echo "============================================================"
  echo "  ham-apps installed successfully!"
  echo "============================================================"
  echo ""
  echo "  Installation directory : $dir"
  echo "  PATH updated in        : $bashrc"
  echo ""
  echo "  To start using ham-apps:"
  echo "    Reload your shell:    source $bashrc"
  echo "    Launch the GUI:       ham-apps"
  echo "    List apps:            ham-apps list"
  echo ""
  echo "  Happy DXing! 73 de KW4JLB"
  echo "============================================================"
  echo ""
}

# ---------------------------------------------------------------------------
# Main — only runs when NOT in test mode
# ---------------------------------------------------------------------------
if [[ "${HAMAPPS_TEST_MODE:-0}" -eq 0 ]]; then
  HAMAPPS_DIR="${HAMAPPS_DIR:-$HOME/ham-apps}"

  if [[ $DRY_RUN -eq 1 ]]; then
    info "Dry-run mode enabled — no changes will be made."
    os_release="${HAMAPPS_TEST_OS_RELEASE:-/etc/os-release}"
    if [[ -f "$os_release" ]]; then
      check_os
    fi
    validate_install_dir "$HAMAPPS_DIR"
    run_cmd curl -fsSL --output /dev/null 'https://go.dev/VERSION?m=text'
    run_cmd sudo rm -rf /usr/local/go
    run_cmd sudo tar -C /usr/local -xzf go-latest.linux-amd64.tar.gz
    run_cmd curl -fsSL --output "$HAMAPPS_DIR/ham-apps-linux-amd64.tar.gz" \
      "https://github.com/KW4JLB/ham-apps/releases/download/<tag>/ham-apps-<tag>-linux-amd64.tar.gz"
    run_cmd tar -xzf ham-apps-linux-amd64.tar.gz -C "$HAMAPPS_DIR" --strip-components=1
    run_cmd bash -c "echo 'export PATH=\"${HAMAPPS_DIR}:\$PATH\"' >> ~/.bashrc"
    run_cmd bash -c "echo 'export PATH=\"/usr/local/go/bin:\$PATH\"' >> ~/.bashrc"
    success "Dry-run complete. No changes made."
    exit 0
  fi

  check_os
  validate_install_dir "$HAMAPPS_DIR"
  install_deps
  install_go
  install_release "$HAMAPPS_DIR"
  configure_path
  print_banner
fi

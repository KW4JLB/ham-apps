#!/bin/bash
set -euo pipefail
# Main GUI window — app browser using yad

HAMAPPS_DIR="$(dirname "$(dirname "$(readlink -f "$0")")")"
source "$HAMAPPS_DIR/scripts/utils"

# GtkSocket/GtkPlug require X11; force XWayland if running under Wayland
export GDK_BACKEND=x11

if ! command -v yad &>/dev/null; then
  error "yad is required for the GUI. Install it with: sudo apt install yad"
  if command -v zenity &>/dev/null; then
    warning "Falling back to zenity (limited functionality)."
  else
    exit 1
  fi
fi

# List unique categories with "All" at top
build_category_list() {
  echo "All"
  for app in $(list_all_apps); do
    get_metadata "$app" category
  done | sort -u
}

# Emit yad row data for each app, optionally filtered by category
build_app_data() {
  local cat_filter="${1:-All}"
  for app in $(list_all_apps); do
    name="$(get_metadata "$app" name)"
    category="$(get_metadata "$app" category)"
    description="$(head -1 "$APPS_DIR/$app/description" 2>/dev/null)"
    [[ "$cat_filter" != "All" && "$category" != "$cat_filter" ]] && continue
    if is_installed "$app"; then
      status="Installed"; status_icon="gtk-yes"
    else
      status="Not installed"; status_icon="gtk-no"
    fi
    echo "$status_icon"
    echo "$name"
    echo "$category"
    echo "$status"
    echo "$description"
    echo "$app"
    echo "${name} ${category} ${description}"  # hidden — search target
  done
}

CATEGORY="All"
SEARCH_TEXT=""

# Main window loop — redisplay after each action
while true; do
  title="ham-apps — Amateur Radio App Manager"
  [[ "$CATEGORY" != "All" ]] && title+=" — $CATEGORY"

  exit_code=0
  SELECTION=$(build_app_data "$CATEGORY" | yad \
    --list \
    --title="$title" \
    --width=960 --height=540 \
    --resizable --maximizable \
    --column="":IMG \
    --column="Name" \
    --column="Category" \
    --column="Status" \
    --column="Description" \
    --column="id":HD \
    --column="":HD \
    --search-column=7 \
    --button="Category\: $CATEGORY:6" \
    --button="Install:2" \
    --button="Uninstall:4" \
    --button="Close:0" \
    --print-column=6 \
    2>/dev/null) || exit_code=$?
  APP_ID=$(echo "$SELECTION" | tr -d '|')

  case $exit_code in
    6) # Category picker
      cat_exit=0
      picked=$(build_category_list | yad \
        --list \
        --title="Select Category" \
        --width=280 --height=380 \
        --no-headers \
        --column="Category" \
        --button="Select:0" \
        --button="Cancel:1" \
        --print-column=1 \
        2>/dev/null) || cat_exit=$?
      [[ $cat_exit -eq 0 && -n "$picked" ]] && CATEGORY=$(echo "$picked" | tr -d '|')
      ;;
    2) # Install
      [[ -z "$APP_ID" ]] && { yad --info --text="Select an app first." 2>/dev/null; continue; }
      "$HAMAPPS_DIR/gui/app-details" "$APP_ID" install ;;
    4) # Uninstall
      [[ -z "$APP_ID" ]] && { yad --info --text="Select an app first." 2>/dev/null; continue; }
      "$HAMAPPS_DIR/gui/app-details" "$APP_ID" uninstall ;;
    0|*) exit 0 ;;
  esac
done

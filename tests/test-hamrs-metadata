#!/bin/bash
# tests/test-hamrs-metadata
# Unit tests for static file correctness of the apps/hamrs/ app entry.
# Red phase: install/uninstall existence tests fail before Phase 2 creates scripts.

REPO_ROOT="$(dirname "$(dirname "$(readlink -f "$0")")")"
APP_DIR="$REPO_ROOT/apps/hamrs"
METADATA="$APP_DIR/metadata"
DESCRIPTION="$APP_DIR/description"
INSTALL="$APP_DIR/install"
UNINSTALL="$APP_DIR/uninstall"
CATEGORIES="$REPO_ROOT/data/categories"

PASS=0
FAIL=0

pass() { echo "PASS: $1"; ((PASS++)) || true; }
fail() { echo "FAIL: $1"; ((FAIL++)) || true; }

# ---------------------------------------------------------------------------
# Test 1: metadata file exists
# ---------------------------------------------------------------------------
if [[ -f "$METADATA" ]]; then
  pass "apps/hamrs/metadata exists"
else
  fail "apps/hamrs/metadata does NOT exist"
fi

# ---------------------------------------------------------------------------
# Test 2: metadata contains name=HAMRS
# ---------------------------------------------------------------------------
if grep -qF 'name=HAMRS' "$METADATA" 2>/dev/null; then
  pass "metadata contains name=HAMRS"
else
  fail "metadata does NOT contain name=HAMRS"
fi

# ---------------------------------------------------------------------------
# Test 3: metadata contains category=logging
# ---------------------------------------------------------------------------
if grep -qF 'category=logging' "$METADATA" 2>/dev/null; then
  pass "metadata contains category=logging"
else
  fail "metadata does NOT contain category=logging"
fi

# ---------------------------------------------------------------------------
# Test 4: metadata category matches a known category in data/categories
# ---------------------------------------------------------------------------
if grep -qF 'logging|' "$CATEGORIES" 2>/dev/null; then
  pass "metadata category 'logging' is defined in data/categories"
else
  fail "metadata category 'logging' is NOT defined in data/categories"
fi

# ---------------------------------------------------------------------------
# Test 5: metadata contains website= starting with https://hamrs.app/
# ---------------------------------------------------------------------------
if grep -qF 'website=https://hamrs.app/' "$METADATA" 2>/dev/null; then
  pass "metadata contains website=https://hamrs.app/"
else
  fail "metadata does NOT contain website=https://hamrs.app/"
fi

# ---------------------------------------------------------------------------
# Test 6: metadata contains tags= with at least one tag
# ---------------------------------------------------------------------------
if grep -qE 'tags=.+' "$METADATA" 2>/dev/null; then
  pass "metadata contains tags= with at least one tag"
else
  fail "metadata does NOT contain tags= with at least one tag"
fi

# ---------------------------------------------------------------------------
# Test 7: metadata contains min-os= field
# ---------------------------------------------------------------------------
if grep -q 'min-os=' "$METADATA" 2>/dev/null; then
  pass "metadata contains min-os= field"
else
  fail "metadata does NOT contain min-os= field"
fi

# ---------------------------------------------------------------------------
# Test 8: description file exists
# ---------------------------------------------------------------------------
if [[ -f "$DESCRIPTION" ]]; then
  pass "apps/hamrs/description exists"
else
  fail "apps/hamrs/description does NOT exist"
fi

# ---------------------------------------------------------------------------
# Test 9: description first line is non-empty and <=120 chars
# ---------------------------------------------------------------------------
first_line="$(head -n1 "$DESCRIPTION" 2>/dev/null || true)"
if [[ -n "$first_line" ]]; then
  len="${#first_line}"
  if [[ "$len" -le 120 ]]; then
    pass "description first line is non-empty and <=120 chars (${len} chars)"
  else
    fail "description first line is too long: ${len} chars (max 120)"
  fi
else
  fail "description first line is empty"
fi

# ---------------------------------------------------------------------------
# Test 10: description mentions POTA
# ---------------------------------------------------------------------------
if grep -qi 'POTA\|Parks on the Air' "$DESCRIPTION" 2>/dev/null; then
  pass "description mentions POTA"
else
  fail "description does NOT mention POTA"
fi

# ---------------------------------------------------------------------------
# Test 11: install file exists and is executable
# ---------------------------------------------------------------------------
if [[ -f "$INSTALL" ]] && [[ -x "$INSTALL" ]]; then
  pass "apps/hamrs/install exists and is executable"
else
  fail "apps/hamrs/install does NOT exist or is NOT executable"
fi

# ---------------------------------------------------------------------------
# Test 12: uninstall file exists and is executable
# ---------------------------------------------------------------------------
if [[ -f "$UNINSTALL" ]] && [[ -x "$UNINSTALL" ]]; then
  pass "apps/hamrs/uninstall exists and is executable"
else
  fail "apps/hamrs/uninstall does NOT exist or is NOT executable"
fi

# ---------------------------------------------------------------------------
# Summary
# ---------------------------------------------------------------------------
echo ""
echo "Results: $PASS passed, $FAIL failed"
if [[ $FAIL -gt 0 ]]; then
  exit 1
fi
exit 0

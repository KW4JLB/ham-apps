#!/bin/bash
# tests/test-install-sh
# Unit tests for install.sh at repo root.
# Red phase: most tests will FAIL before install.sh is created.
# Run: bash tests/test-install-sh

REPO_ROOT="$(dirname "$(dirname "$(readlink -f "$0")")")"
INSTALL_SH="$REPO_ROOT/install.sh"

PASS=0
FAIL=0

pass() { echo "PASS: $1"; ((PASS++)) || true; }
fail() { echo "FAIL: $1"; ((FAIL++)) || true; }

# ---------------------------------------------------------------------------
# UT-1: Script has correct shebang
# ---------------------------------------------------------------------------
if [[ ! -f "$INSTALL_SH" ]]; then
  fail "UT-1: install.sh not found — cannot check shebang"
else
  first_line="$(head -1 "$INSTALL_SH")"
  if [[ "$first_line" == "#!/bin/bash" || "$first_line" == "#!/usr/bin/env bash" ]]; then
    pass "UT-1: install.sh has a valid bash shebang"
  else
    fail "UT-1: install.sh shebang is not #!/bin/bash or #!/usr/bin/env bash (got: $first_line)"
  fi
fi

# ---------------------------------------------------------------------------
# UT-2: set -euo pipefail is present
# ---------------------------------------------------------------------------
if [[ ! -f "$INSTALL_SH" ]]; then
  fail "UT-2: install.sh not found — cannot check set -euo pipefail"
else
  if grep -q 'set -euo pipefail' "$INSTALL_SH"; then
    pass "UT-2: install.sh contains set -euo pipefail"
  else
    fail "UT-2: install.sh does not contain set -euo pipefail"
  fi
fi

# ---------------------------------------------------------------------------
# UT-3: shellcheck passes
# ---------------------------------------------------------------------------
if [[ ! -f "$INSTALL_SH" ]]; then
  fail "UT-3: install.sh not found — cannot run shellcheck"
elif ! command -v shellcheck &>/dev/null; then
  echo "SKIP: UT-3: shellcheck not installed — skipping lint check"
else
  if shellcheck -x "$INSTALL_SH" 2>/dev/null; then
    pass "UT-3: shellcheck passes on install.sh"
  else
    fail "UT-3: shellcheck reports warnings or errors on install.sh"
  fi
fi

# ---------------------------------------------------------------------------
# UT-4: --help flag exits 0 and prints Usage:
# ---------------------------------------------------------------------------
if [[ ! -f "$INSTALL_SH" ]]; then
  fail "UT-4: install.sh not found — cannot test --help"
else
  help_output="$(bash "$INSTALL_SH" --help 2>&1)" && help_exit=0 || help_exit=$?
  if [[ $help_exit -eq 0 ]] && echo "$help_output" | grep -q 'Usage:'; then
    pass "UT-4: install.sh --help exits 0 and prints Usage:"
  elif [[ $help_exit -ne 0 ]]; then
    fail "UT-4: install.sh --help exited with code $help_exit"
  else
    fail "UT-4: install.sh --help did not print 'Usage:' (got: ${help_output:0:120})"
  fi
fi

# ---------------------------------------------------------------------------
# UT-5: --dry-run flag exits 0 without making changes
# ---------------------------------------------------------------------------
if [[ ! -f "$INSTALL_SH" ]]; then
  fail "UT-5: install.sh not found — cannot test --dry-run"
else
  # Provide a mock OS release so the OS check passes regardless of actual host
  tmpdir="$(mktemp -d)"
  cat >"$tmpdir/os-release" <<'EOF'
ID=ubuntu
VERSION_ID=22.04
EOF
  # Redirect HOME to tmp so no real RC files are touched; override HAMAPPS_DIR
  dry_output="$(HOME="$tmpdir" HAMAPPS_DIR="$tmpdir/ham-apps" HAMAPPS_TEST_OS_RELEASE="$tmpdir/os-release" bash "$INSTALL_SH" --dry-run 2>&1)" && dry_exit=0 || dry_exit=$?
  rm -rf "$tmpdir"
  if [[ $dry_exit -eq 0 ]]; then
    pass "UT-5: install.sh --dry-run exits 0"
  else
    fail "UT-5: install.sh --dry-run exited with code $dry_exit (output: ${dry_output:0:200})"
  fi
fi

# ---------------------------------------------------------------------------
# UT-6: OS detection rejects unsupported distro (fedora)
# ---------------------------------------------------------------------------
if [[ ! -f "$INSTALL_SH" ]]; then
  fail "UT-6: install.sh not found — cannot test OS detection"
else
  tmpdir="$(mktemp -d)"
  cat >"$tmpdir/os-release" <<'EOF'
ID=fedora
VERSION_ID=38
EOF
  HAMAPPS_TEST_OS_RELEASE="$tmpdir/os-release" HAMAPPS_TEST_MODE=1 bash -c "
    source '$INSTALL_SH'
    check_os 2>/dev/null
  " && fedora_exit=0 || fedora_exit=$?
  rm -rf "$tmpdir"
  if [[ $fedora_exit -ne 0 ]]; then
    pass "UT-6: OS detection rejects unsupported distro (fedora)"
  else
    fail "UT-6: OS detection should reject fedora but exited 0"
  fi
fi

# ---------------------------------------------------------------------------
# UT-7: OS detection accepts Debian 11
# ---------------------------------------------------------------------------
if [[ ! -f "$INSTALL_SH" ]]; then
  fail "UT-7: install.sh not found — cannot test OS detection"
else
  tmpdir="$(mktemp -d)"
  cat >"$tmpdir/os-release" <<'EOF'
ID=debian
VERSION_ID=11
EOF
  HAMAPPS_TEST_OS_RELEASE="$tmpdir/os-release" HAMAPPS_TEST_MODE=1 bash -c "
    source '$INSTALL_SH'
    check_os 2>/dev/null
  " && debian11_exit=0 || debian11_exit=$?
  rm -rf "$tmpdir"
  if [[ $debian11_exit -eq 0 ]]; then
    pass "UT-7: OS detection accepts Debian 11"
  else
    fail "UT-7: OS detection should accept Debian 11 but exited $debian11_exit"
  fi
fi

# ---------------------------------------------------------------------------
# UT-8: OS detection accepts Ubuntu 20.04
# ---------------------------------------------------------------------------
if [[ ! -f "$INSTALL_SH" ]]; then
  fail "UT-8: install.sh not found — cannot test OS detection"
else
  tmpdir="$(mktemp -d)"
  cat >"$tmpdir/os-release" <<'EOF'
ID=ubuntu
VERSION_ID=20.04
EOF
  HAMAPPS_TEST_OS_RELEASE="$tmpdir/os-release" HAMAPPS_TEST_MODE=1 bash -c "
    source '$INSTALL_SH'
    check_os 2>/dev/null
  " && ubuntu2004_exit=0 || ubuntu2004_exit=$?
  rm -rf "$tmpdir"
  if [[ $ubuntu2004_exit -eq 0 ]]; then
    pass "UT-8: OS detection accepts Ubuntu 20.04"
  else
    fail "UT-8: OS detection should accept Ubuntu 20.04 but exited $ubuntu2004_exit"
  fi
fi

# ---------------------------------------------------------------------------
# UT-9: OS detection rejects Debian 10
# ---------------------------------------------------------------------------
if [[ ! -f "$INSTALL_SH" ]]; then
  fail "UT-9: install.sh not found — cannot test OS detection"
else
  tmpdir="$(mktemp -d)"
  cat >"$tmpdir/os-release" <<'EOF'
ID=debian
VERSION_ID=10
EOF
  HAMAPPS_TEST_OS_RELEASE="$tmpdir/os-release" HAMAPPS_TEST_MODE=1 bash -c "
    source '$INSTALL_SH'
    check_os 2>/dev/null
  " && debian10_exit=0 || debian10_exit=$?
  rm -rf "$tmpdir"
  if [[ $debian10_exit -ne 0 ]]; then
    pass "UT-9: OS detection rejects Debian 10"
  else
    fail "UT-9: OS detection should reject Debian 10 but exited 0"
  fi
fi

# ---------------------------------------------------------------------------
# UT-10: OS detection rejects Ubuntu 18.04
# ---------------------------------------------------------------------------
if [[ ! -f "$INSTALL_SH" ]]; then
  fail "UT-10: install.sh not found — cannot test OS detection"
else
  tmpdir="$(mktemp -d)"
  cat >"$tmpdir/os-release" <<'EOF'
ID=ubuntu
VERSION_ID=18.04
EOF
  HAMAPPS_TEST_OS_RELEASE="$tmpdir/os-release" HAMAPPS_TEST_MODE=1 bash -c "
    source '$INSTALL_SH'
    check_os 2>/dev/null
  " && ubuntu1804_exit=0 || ubuntu1804_exit=$?
  rm -rf "$tmpdir"
  if [[ $ubuntu1804_exit -ne 0 ]]; then
    pass "UT-10: OS detection rejects Ubuntu 18.04"
  else
    fail "UT-10: OS detection should reject Ubuntu 18.04 but exited 0"
  fi
fi

# ---------------------------------------------------------------------------
# UT-11: PATH line not duplicated on second run
# ---------------------------------------------------------------------------
if [[ ! -f "$INSTALL_SH" ]]; then
  fail "UT-11: install.sh not found — cannot test PATH deduplication"
else
  tmpdir="$(mktemp -d)"
  fake_bashrc="$tmpdir/.bashrc"
  touch "$fake_bashrc"
  # Call the configure_path function twice with a mock HAMAPPS_DIR
  HAMAPPS_TEST_MODE=1 bash -c "
    HAMAPPS_DIR='$tmpdir/ham-apps'
    BASHRC_FILE='$fake_bashrc'
    source '$INSTALL_SH'
    configure_path 2>/dev/null
    configure_path 2>/dev/null
  " 2>/dev/null || true
  line_count="$(grep -c "ham-apps" "$fake_bashrc" 2>/dev/null || echo 0)"
  rm -rf "$tmpdir"
  if [[ "$line_count" -le 1 ]]; then
    pass "UT-11: PATH line not duplicated after double configure_path call"
  else
    fail "UT-11: PATH line was duplicated ($line_count occurrences found)"
  fi
fi

# ---------------------------------------------------------------------------
# UT-12: HAMAPPS_DIR env var is honoured
# ---------------------------------------------------------------------------
if [[ ! -f "$INSTALL_SH" ]]; then
  fail "UT-12: install.sh not found — cannot test HAMAPPS_DIR override"
else
  if grep -q 'HAMAPPS_DIR' "$INSTALL_SH"; then
    pass "UT-12: install.sh references HAMAPPS_DIR variable"
  else
    fail "UT-12: install.sh does not reference HAMAPPS_DIR variable"
  fi
fi

# ---------------------------------------------------------------------------
# UT-13: Script is executable
# ---------------------------------------------------------------------------
if [[ ! -f "$INSTALL_SH" ]]; then
  fail "UT-13: install.sh not found — cannot check executable bit"
else
  if [[ -x "$INSTALL_SH" ]]; then
    pass "UT-13: install.sh is executable"
  else
    fail "UT-13: install.sh is not executable (missing +x bit)"
  fi
fi

# ---------------------------------------------------------------------------
# UT-14: validate_install_dir rejects paths with shell metacharacters
# ---------------------------------------------------------------------------
if [[ ! -f "$INSTALL_SH" ]]; then
  fail "UT-14: install.sh not found — cannot test validate_install_dir"
else
  HAMAPPS_TEST_MODE=1 bash -c "
    source '$INSTALL_SH'
    validate_install_dir '/tmp/\$(evil)' 2>/dev/null
  " && meta_exit=0 || meta_exit=$?
  if [[ $meta_exit -ne 0 ]]; then
    pass "UT-14: validate_install_dir rejects path with shell metacharacters"
  else
    fail "UT-14: validate_install_dir should reject metacharacter path but exited 0"
  fi
fi

# ---------------------------------------------------------------------------
# UT-15: validate_install_dir accepts a clean absolute path
# ---------------------------------------------------------------------------
if [[ ! -f "$INSTALL_SH" ]]; then
  fail "UT-15: install.sh not found — cannot test validate_install_dir"
else
  HAMAPPS_TEST_MODE=1 bash -c "
    source '$INSTALL_SH'
    validate_install_dir '/home/user/ham-apps' 2>/dev/null
  " && clean_exit=0 || clean_exit=$?
  if [[ $clean_exit -eq 0 ]]; then
    pass "UT-15: validate_install_dir accepts clean absolute path"
  else
    fail "UT-15: validate_install_dir rejected clean path (exited $clean_exit)"
  fi
fi

# ---------------------------------------------------------------------------
# Summary
# ---------------------------------------------------------------------------
echo ""
echo "Results: $PASS passed, $FAIL failed"
if [[ $FAIL -gt 0 ]]; then
  exit 1
fi
exit 0

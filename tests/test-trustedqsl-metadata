#!/bin/bash
# tests/test-trustedqsl-metadata
# Unit tests for static file correctness of the apps/trustedqsl/ app entry.
# Red phase: these tests must FAIL before Phase 2 creates the app files.

REPO_ROOT="$(dirname "$(dirname "$(readlink -f "$0")")")"
APP_DIR="$REPO_ROOT/apps/trustedqsl"
METADATA="$APP_DIR/metadata"
DESCRIPTION="$APP_DIR/description"
INSTALL="$APP_DIR/install"
UNINSTALL="$APP_DIR/uninstall"

PASS=0
FAIL=0

pass() { echo "PASS: $1"; ((PASS++)) || true; }
fail() { echo "FAIL: $1"; ((FAIL++)) || true; }

# ---------------------------------------------------------------------------
# Test 1: metadata file exists
# ---------------------------------------------------------------------------
if [[ -f "$METADATA" ]]; then
  pass "apps/trustedqsl/metadata exists"
else
  fail "apps/trustedqsl/metadata does NOT exist"
fi

# ---------------------------------------------------------------------------
# Test 2: metadata contains name=Trusted QSL
# ---------------------------------------------------------------------------
if grep -q 'name=Trusted QSL' "$METADATA" 2>/dev/null; then
  pass "metadata contains name=Trusted QSL"
else
  fail "metadata does NOT contain name=Trusted QSL"
fi

# ---------------------------------------------------------------------------
# Test 3: metadata contains category=tools
# ---------------------------------------------------------------------------
if grep -q 'category=tools' "$METADATA" 2>/dev/null; then
  pass "metadata contains category=tools"
else
  fail "metadata does NOT contain category=tools"
fi

# ---------------------------------------------------------------------------
# Test 4: metadata contains website= starting with https://
# ---------------------------------------------------------------------------
if grep -q 'website=https://' "$METADATA" 2>/dev/null; then
  pass "metadata contains website= starting with https://"
else
  fail "metadata does NOT contain website= starting with https://"
fi

# ---------------------------------------------------------------------------
# Test 5: metadata contains tags= with at least one tag
# ---------------------------------------------------------------------------
if grep -qE 'tags=.+' "$METADATA" 2>/dev/null; then
  pass "metadata contains tags= with at least one tag"
else
  fail "metadata does NOT contain tags= with at least one tag"
fi

# ---------------------------------------------------------------------------
# Test 6: metadata contains min-os= field
# ---------------------------------------------------------------------------
if grep -q 'min-os=' "$METADATA" 2>/dev/null; then
  pass "metadata contains min-os= field"
else
  fail "metadata does NOT contain min-os= field"
fi

# ---------------------------------------------------------------------------
# Test 7: description file exists
# ---------------------------------------------------------------------------
if [[ -f "$DESCRIPTION" ]]; then
  pass "apps/trustedqsl/description exists"
else
  fail "apps/trustedqsl/description does NOT exist"
fi

# ---------------------------------------------------------------------------
# Test 8: description first line is non-empty (short summary)
# ---------------------------------------------------------------------------
first_line="$(head -n1 "$DESCRIPTION" 2>/dev/null || true)"
if [[ -n "$first_line" ]]; then
  pass "description first line is non-empty"
else
  fail "description first line is empty"
fi

# ---------------------------------------------------------------------------
# Test 9: install file exists and is executable
# ---------------------------------------------------------------------------
if [[ -f "$INSTALL" ]] && [[ -x "$INSTALL" ]]; then
  pass "apps/trustedqsl/install exists and is executable"
else
  fail "apps/trustedqsl/install does NOT exist or is NOT executable"
fi

# ---------------------------------------------------------------------------
# Test 10: uninstall file exists and is executable
# ---------------------------------------------------------------------------
if [[ -f "$UNINSTALL" ]] && [[ -x "$UNINSTALL" ]]; then
  pass "apps/trustedqsl/uninstall exists and is executable"
else
  fail "apps/trustedqsl/uninstall does NOT exist or is NOT executable"
fi

# ---------------------------------------------------------------------------
# Summary
# ---------------------------------------------------------------------------
echo ""
echo "Results: $PASS passed, $FAIL failed"
if [[ $FAIL -gt 0 ]]; then
  exit 1
fi
exit 0

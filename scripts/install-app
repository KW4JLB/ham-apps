#!/bin/bash
# Install a ham-apps application

HAMAPPS_DIR="$(dirname "$(dirname "$(readlink -f "$0")")")"
source "$HAMAPPS_DIR/scripts/utils"

APP="$1"
[[ -z "$APP" ]] && { error "Usage: ham-apps install <app-name>"; exit 1; }

require_app "$APP"

if is_installed "$APP"; then
  warning "$APP is already installed."
  exit 0
fi

info "Installing $APP..."
install_script="$APPS_DIR/$APP/install"

if [[ ! -f "$install_script" ]]; then
  error "No install script found for $APP."
  exit 1
fi

bash "$install_script"
exit_code=$?

if [[ $exit_code -eq 0 ]]; then
  mark_installed "$APP"
  success "$APP installed successfully."
else
  error "$APP installation failed (exit code $exit_code)."
  exit $exit_code
fi
